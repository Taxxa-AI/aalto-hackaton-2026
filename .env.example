# Copy to .env and fill in what you need. Never commit .env.

# --- LLM providers (pick at least one) ----------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Corpus download ----------------------------------------------------
# Override if you fork the repo and host the release elsewhere.
TAXXA_DATA_RELEASE=https://github.com/Taxxa-AI/aalto-hackaton-2026/releases/download/data-v1

# --- Optional: Neo4j ----------------------------------------------------
# Only needed if you `docker compose up` the graph store. Defaults match
# the docker-compose.yml in this repo.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
